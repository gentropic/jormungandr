# local spec drafts — the inbox stays private; ratified specs graduate to the repo root
spec_inbox/*
!spec_inbox/.gitkeep

# node secrets: wifi credentials + bearer token live here, never in git
settings.json
*.secrets.json

# python
__pycache__/
*.pyc

# tooling / editors
node_modules/
.vscode/
.idea/
.DS_Store

# AI / agent scratch — jormungandr is driven from outside this repo
CLAUDE.md
AGENTS.md
.claude/

# sim node "flash" — a scratch filesystem, never committed
sim/fs/*
!sim/fs/.gitkeep

# board tooling venv (esptool + mpremote + pyserial): see tools/README.md
.venv/

# built artifact: the tool gzips ui.html at push time
supervisor/ui.html.gz

supervisor/web/*.gz
sim/fs2/
sim/fs-cl*/
sim/fs-br*/
sim/fs-flag/
sim/fs-leaf/
